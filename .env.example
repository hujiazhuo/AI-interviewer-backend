# DeepSeek cloud config
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v3
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

# Tavily (web search fallback)
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search

# RAG core config
KNOWLEDGE_DIR=./knowledge
RAG_COLLECTION_NAME=interview_kb
RAG_PERSIST_DIR=./data/chroma
SIMILARITY_THRESHOLD=0.80
RAG_TOP_K_RETRIEVE=10
RAG_TOP_K_RERANK=3
ENABLE_TAVILY_FALLBACK=true
WRITEBACK_ON_WEB_MODE=true
WRITEBACK_MIN_WEB_SCORE=0.65
WRITEBACK_MIN_ANSWER_LEN=20
EVOLUTION_KB_FILE=evolution_kb.md
